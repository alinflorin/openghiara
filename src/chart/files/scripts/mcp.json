{
  "$schema": "https://docs.1mcp.app/schemas/v1.0.0/mcp-config.json",
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "mcp-filesystem-server"]
    },
    "shell": {
      "command": "npx",
      "args": ["-y", "bash-mcp"]
    },
    "chrome-browser": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp"]
    }
  }
}
