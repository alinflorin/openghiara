{
  "mcpServers": {
    "fs": {
      "command": "npx",
      "args": ["-y", "mcp-filesystem-server"]
    },
    "sh": {
      "command": "npx",
      "args": ["-y", "bash-mcp"]
    },
    "chrome": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp",
        "-e",
        "/home/kasm-user/Software/chromium/chrome"
      ]
    },
    "control": {
      "command": "mcp-pyautogui",
      "args": [""],
      "env": {
        "DISPLAY": ":1"
      }
    }
  }
}
