{
  "mcpServers": {
    "fs": {
      "command": "npx",
      "args": ["-y", "mcp-filesystem-server"]
    },
    "sh": {
      "command": "npx",
      "args": ["-y", "bash-mcp"]
    },
    "control": {
      "command": "uvx",
      "args": ["ubuntu-desktop-control"],
      "env": {
        "DISPLAY": ":1"
      }
    }
  }
}
